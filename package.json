    "ws": "^7.5.11"
  },
  "scripts": {
    "calendar:init": "node --require dotenv-flow/config ./src/scripts/initialize.js",
    "start": "yarn ts .",
    "dev": "NODE_ENV=development nodemon -e ts -w ./src -x yarn ts .",
    "lint": "tsc && eslint src test",
