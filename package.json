    "eslint": "^8.7.0",
    "eslint-config-prettier": "7.1.0",
    "eslint-plugin-import": "2.22.1",
    "eslint-plugin-jest": "25.3.2",
    "eslint-plugin-jsx-a11y": "6.x",
    "eslint-plugin-prettier": "3.3.0",
    "jest": "27.4.6",
    "nodemon": "2.0.7",
    "prettier": "2.5.1",
    "supertest": "6.1.6",
    "ts-jest": "27.1.2",
    "typescript": "^4.5.5"
